# Copy this file to ".env" and paste your real Gemini API key below
GEMINI_API_KEY=your_gemini_api_key_here
PORT=8088

# Production: set this to your deployed Vercel URL (comma-separate if you
# have multiple, e.g. prod + preview). Leave unset locally to allow all.
CLIENT_ORIGIN=https://your-app.vercel.app

# Rate limiting for the chat endpoints (protects your Gemini quota/billing
# from abuse). Defaults: 30 requests per 15-minute window, per IP.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=30
